{
  "_comment": "Oshxona POS tizimi — kutilayotgan javoblar formati. Har bir endpoint uchun HTTP status va field struktura.",
  "_version": "3.1.0",
  "_updated": "2026-04-28",

  "sections": {
    "1_auth": {
      "title": "Authentication",
      "endpoints": {
        "1.1_login": {
          "method": "POST",
          "path": "/api/auth/login",
          "expectedStatus": 200,
          "body": { "email": "string", "password": "string" },
          "response": {
            "success": true,
            "data": {
              "accessToken":  "string (JWT, expires 15m)",
              "refreshToken": "string (JWT, expires 7d)",
              "user": {
                "id":        "UUID",
                "email":     "string",
                "firstName": "string",
                "lastName":  "string",
                "role":      "SUPER_ADMIN | MANAGER | CASHIER | CHEF | WAITER | WAREHOUSE | ACCOUNTANT",
                "tenantId":  "UUID | null",
                "isActive":  true
              }
            }
          }
        },
        "1.2_login_pin": {
          "method": "POST",
          "path": "/api/auth/login-pin",
          "expectedStatus": 200,
          "body": { "pin": "string (4 digits)", "tenantId": "UUID" },
          "response": {
            "success": true,
            "data": { "accessToken": "string", "user": "object" }
          }
        },
        "1.3_refresh": {
          "method": "POST",
          "path": "/api/auth/refresh",
          "expectedStatus": 200,
          "body": { "refreshToken": "string" },
          "response": {
            "success": true,
            "data": {
              "accessToken":  "string (new JWT)",
              "refreshToken": "string (new refresh)"
            }
          }
        },
        "1.4_me": {
          "method": "GET",
          "path": "/api/auth/me",
          "expectedStatus": 200,
          "auth": "Bearer token",
          "response": {
            "success": true,
            "data": {
              "id": "UUID", "email": "string", "role": "string",
              "firstName": "string", "lastName": "string",
              "tenantId": "UUID | null", "isActive": true
            }
          }
        },
        "1.5_change_password": {
          "method": "PUT",
          "path": "/api/auth/change-password",
          "expectedStatus": 200,
          "body": { "oldPassword": "string", "newPassword": "string (min 8 chars)" },
          "response": { "success": true, "message": "Parol muvaffaqiyatli o'zgartirildi" }
        },
        "1.6_logout": {
          "method": "POST",
          "path": "/api/auth/logout",
          "expectedStatus": 200,
          "response": { "success": true }
        }
      }
    },

    "2_users": {
      "title": "User Management",
      "endpoints": {
        "2.1_create": {
          "method": "POST",
          "path": "/api/users",
          "expectedStatus": 201,
          "roles": ["MANAGER", "SUPER_ADMIN"],
          "body": {
            "email":     "string (unique per tenant)",
            "password":  "string (min 8)",
            "firstName": "string",
            "lastName":  "string",
            "role":      "CASHIER | WAITER | CHEF | WAREHOUSE | ACCOUNTANT | MANAGER",
            "phone":     "string (optional)"
          },
          "response": {
            "success": true,
            "data": { "id": "UUID", "email": "string", "role": "string", "isActive": true }
          }
        },
        "2.2_list": {
          "method": "GET",
          "path": "/api/users",
          "expectedStatus": 200,
          "response": {
            "success": true,
            "data": [{ "id": "UUID", "email": "string", "role": "string", "isActive": true }],
            "meta": { "total": "number", "page": 1, "limit": 20 }
          }
        },
        "2.3_get_one": {
          "method": "GET",
          "path": "/api/users/:id",
          "expectedStatus": 200,
          "response": { "success": true, "data": { "id": "UUID" } }
        },
        "2.4_update": {
          "method": "PUT",
          "path": "/api/users/:id",
          "expectedStatus": 200,
          "body": { "firstName": "string", "lastName": "string", "phone": "string" },
          "response": { "success": true, "data": { "id": "UUID" } }
        },
        "2.5_pin": {
          "method": "PUT",
          "path": "/api/auth/users/:userId/pin",
          "expectedStatus": 200,
          "body": { "pin": "string (4 digits)" },
          "response": { "success": true }
        }
      }
    },

