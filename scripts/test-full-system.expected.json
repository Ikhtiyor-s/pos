    "11_payments": {
      "title": "Payment Integrations",
      "endpoints": {
        "11.1_payme": {
          "method": "POST",
          "path": "/api/payments/payme/callback",
          "auth": "None (HMAC verified internally)",
          "note": "Payme JSON-RPC 2.0 protokoli",
          "supportedMethods": [
            "CheckPerformTransaction",
            "CreateTransaction",
            "PerformTransaction",
            "CancelTransaction",
            "CheckTransaction",
            "GetStatement"
          ],
          "body": {
            "id":     "number (JSON-RPC id)",
            "method": "string",
            "params": "object"
          },
          "response": {
            "id":     "number",
            "result": "object | null",
            "error":  "object | null"
          }
        },
        "11.2_click": {
          "method": "POST",
          "path": "/api/payments/click/prepare",
          "auth": "None (HMAC-MD5 verified internally)",
          "note": "Click 2-step payment: prepare → complete",
          "body": {
            "click_trans_id":  "string",
            "service_id":      "string",
            "merchant_trans_id": "string (orderId)",
            "amount":          "number",
            "action":          "0 (prepare) | 1 (complete)",
            "sign_time":       "string",
            "sign_string":     "string (MD5 hash)"
          },
          "response": {
            "click_trans_id":     "string",
            "merchant_trans_id":  "string",
            "merchant_confirm_id":"string",
            "error":              "0 (success) | negative (error)",
            "error_note":         "string"
          }
        }
      }
    },

