    "7_markirovka": {
      "title": "O'zbekiston Markirovka Tizimi",
      "endpoints": {
        "7.1_verify": {
          "method": "POST",
          "path": "/api/markirovka/verify/:code",
          "expectedStatus": "200 | 202",
          "note": "202 qaytsa — kod offline queue ga qo'shildi (internet yo'q)",
          "response": {
            "online_success": {
              "success": true,
              "data": {
                "valid":            true,
                "gtin":             "string (14 digits)",
                "serialNumber":     "string",
                "productName":      "string | null",
                "expiryDate":       "ISO string | null",
                "manufacturerName": "string | null",
                "status":           "string"
              }
            },
            "offline_queued": {
              "success": true,
              "data": { "valid": false, "queued": true, "status": "QUEUED" },
              "message": "Internet mavjud emas — tekshiruv navbatga qo'shildi"
            }
          }
        },
        "7.3_check": {
          "method": "GET",
          "path": "/api/markirovka/check/:code",
          "expectedStatus": 200,
          "note": "Bu endpoint HAMMA VAQT 200 qaytaradi. valid:false bo'lsa sotish mumkin emas.",
          "response": {
            "success": true,
            "data": {
              "valid":   "boolean",
              "reason":  "string | null (agar valid:false bo'lsa sababi)",
              "product": {
                "id":           "UUID | null",
                "gtin":         "string",
                "serialNumber": "string",
                "batchNumber":  "string | null",
                "expiryDate":   "ISO string | null",
                "status":       "IN_STOCK | SOLD | EXPIRED | RESERVED | MANUFACTURED | IMPORTED"
              }
            }
          },
          "errorReasons": [
            "Markirovka kodi bazada topilmadi",
            "Mahsulot allaqachon sotilgan",
            "Mahsulot muddati o'tgan",
            "Mahsulot boshqa buyurtma uchun band",
            "Bu markirovka kodi ushbu restoran uchun emas",
            "Davlat serveri kodni tasdiqlamadi"
          ]
        },
        "7.4_expired": {
          "method": "GET",
          "path": "/api/markirovka/expired",
          "expectedStatus": 200,
          "response": {
            "success": true,
            "data": [{
              "id":          "UUID",
              "markCode":    "string",
              "gtin":        "string",
              "expiryDate":  "ISO string",
              "status":      "EXPIRED",
              "product": { "id": "UUID", "name": "string", "sku": "string | null" }
            }]
          }
        },
        "7.5_daily_report": {
          "method": "GET",
          "path": "/api/markirovka/report/daily",
          "expectedStatus": 200,
          "queryParams": { "date": "YYYY-MM-DD (optional, default: today)" },
          "response": {
            "success": true,
            "data": {
              "date":      "YYYY-MM-DD",
              "received":  "number",
              "verified":  "number",
              "sold":      "number",
              "failed":    "number",
              "queued":    "number",
              "byStatus":  { "IN_STOCK": "number", "SOLD": "number", "EXPIRED": "number" },
              "topGtins":  [{ "gtin": "string", "count": "number" }]
            }
          }
        }
      }
    },

    "8_orders": {
      "title": "Order Management",
      "endpoints": {
        "8.1_create": {
          "method": "POST",
          "path": "/api/orders",
          "expectedStatus": 201,
          "body": {
            "source":      "POS_ORDER | WAITER_ORDER | QR_ORDER | TELEGRAM_ORDER | WEBSITE_ORDER | API_ORDER | WEBHOOK_ORDER",
            "type":        "DINE_IN | TAKEAWAY | DELIVERY",
            "tableId":     "UUID (optional, DINE_IN uchun)",
            "customerId":  "UUID (optional)",
            "items": [{ "productId": "UUID", "quantity": "number (positive)", "notes": "string (optional)" }],
            "discount":        "number (optional, so'm)",
            "discountPercent": "number (optional, 0-100%)",
            "notes":           "string (optional)",
            "address":         "string (optional, DELIVERY uchun)"
          },
          "response": {
            "success": true,
            "data": {
              "id":          "UUID",
              "orderNumber": "string (e.g. ORD-001)",
              "status":      "NEW",
              "source":      "string",
              "type":        "string",
              "subtotal":    "Decimal string",
              "discount":    "Decimal string",
              "tax":         "Decimal string",
              "total":       "Decimal string",
              "items":       [{ "id": "UUID", "productId": "UUID", "quantity": "number", "price": "string" }],
              "payments":    [],
              "table":       "object | null",
              "customer":    "object | null",
              "createdAt":   "ISO string"
            }
          }
        },
        "8.4_status": {
          "method": "PATCH",
          "path": "/api/orders/:id/status",
          "expectedStatus": 200,
          "body": { "status": "NEW | CONFIRMED | PREPARING | READY | DELIVERING | COMPLETED | CANCELLED" },
          "statusFlow": "NEW → CONFIRMED → PREPARING → READY → DELIVERING → COMPLETED",
          "response": {
            "success": true,
            "data": { "id": "UUID", "status": "string" },
            "message": "string"
          }
        },
        "8.6_payment": {
          "method": "POST",
          "path": "/api/orders/:id/payment",
          "expectedStatus": 200,
          "body": {
            "method":    "CASH | CARD | PAYME | CLICK | UZUM | HUMO | OTHER",
            "amount":    "number (UZS)",
            "reference": "string (optional, transaction ID)"
          },
          "response": {
            "success": true,
            "data": {
              "id":          "UUID",
              "status":      "string",
              "total":       "Decimal string",
              "payments": [{ "id": "UUID", "method": "string", "amount": "string", "status": "COMPLETED" }]
            }
          }
        }
      }
    },

