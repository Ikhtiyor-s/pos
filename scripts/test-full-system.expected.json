    "4_products": {
      "title": "Product Management",
      "endpoints": {
        "4.1_create": {
          "method": "POST",
          "path": "/api/products",
          "expectedStatus": 201,
          "body": {
            "name":       "string",
            "price":      "number (UZS, e.g. 15000)",
            "categoryId": "UUID",
            "nameRu":     "string (optional)",
            "description":"string (optional)",
            "barcode":    "string (optional, unique per tenant)",
            "costPrice":  "number (optional)",
            "weight":     "number (optional)",
            "weightUnit": "g | kg | ml | litr | dona",
            "cookingTime":"number (minutes, optional)",
            "calories":   "number (optional)",
            "tags":       "string[] (optional)",
            "mxikCode":   "string (9 or 14 digits, optional)",
            "mxikVatRate":"0 | 12 | 20 (optional)"
          },
          "response": {
            "success": true,
            "data": {
              "id":         "UUID",
              "name":       "string",
              "price":      "Decimal string",
              "categoryId": "UUID",
              "isActive":   true,
              "barcode":    "string | null"
            }
          }
        },
        "4.2_list": {
          "method": "GET",
          "path": "/api/products",
          "expectedStatus": 200,
          "queryParams": { "categoryId": "UUID (optional)", "isActive": "true|false (optional)", "page": 1, "limit": 20 },
          "response": {
            "success": true,
            "data": [{ "id": "UUID", "name": "string", "price": "string", "category": { "id": "UUID" } }],
            "meta": { "total": "number", "page": 1, "limit": 20, "totalPages": "number" }
          }
        },
        "4.6_barcode": {
          "method": "GET",
          "path": "/api/products/barcode/:barcode",
          "expectedStatus": 200,
          "response": { "success": true, "data": { "id": "UUID", "name": "string", "price": "string" } },
          "errorResponse": { "success": false, "message": "Barcode bo'yicha mahsulot topilmadi" }
        }
      }
    },

