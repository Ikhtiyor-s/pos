# ==========================================
# OSHXONA POS — Environment Variables
# ==========================================
# Faylni nusxalab .env deb nomlang va qiymatlarni to'ldiring

# Server
NODE_ENV=production
PORT=3000

# Database (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://pos_user:STRONG_PASSWORD@localhost:5432/oshxona_pos

# JWT Secrets — kamida 32 ta tasodifiy belgi (openssl rand -base64 32)
JWT_SECRET=REPLACE_WITH_MIN_32_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_MIN_32_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# CORS — vergul bilan ajratilgan frontend URL lari (production'da shart)
CLIENT_URL=https://pos.sizningdomen.uz,https://admin.sizningdomen.uz

# Logging
LOG_LEVEL=info
