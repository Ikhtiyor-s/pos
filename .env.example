# ==========================================
# OSHXONA POS TIZIMI - Environment Variables
# ==========================================

# Database
DATABASE_URL="postgresql://oshxona:oshxona_secret_2024@localhost:5432/oshxona_pos"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
NODE_ENV="development"
PORT=3000
API_URL="http://localhost:3000"
CLIENT_URL="http://localhost:5173"

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# Payment Gateways
# Payme
PAYME_MERCHANT_ID=""
PAYME_SECRET_KEY=""
PAYME_TEST_MODE=true

# Click
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""
CLICK_TEST_MODE=true

# Uzum Bank
UZUM_MERCHANT_ID=""
UZUM_SECRET_KEY=""
UZUM_TEST_MODE=true

# SMS Service (Eskiz.uz)
SMS_EMAIL=""
SMS_PASSWORD=""
SMS_TOKEN=""

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
