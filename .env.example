# ==========================================
# OSHXONA POS TIZIMI - Environment Variables
# ==========================================

# Database
POSTGRES_USER=oshxona
POSTGRES_PASSWORD=<KUCHLI_PAROL>
POSTGRES_DB=oshxona_pos
DATABASE_URL="postgresql://oshxona:<KUCHLI_PAROL>@localhost:5432/oshxona_pos"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secrets
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<KUCHLI_RANDOM_64_BYTE_HEX>
JWT_REFRESH_SECRET=<KUCHLI_RANDOM_64_BYTE_HEX>
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
NODE_ENV=production
PORT=3000
API_URL=https://api.yourdomain.com
CLIENT_URL=https://pos.yourdomain.com

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# Payment Gateways
# Payme
PAYME_MERCHANT_ID=""
PAYME_SECRET_KEY=""
PAYME_TEST_MODE=true

# Click
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""
CLICK_TEST_MODE=true

# Uzum Bank
UZUM_MERCHANT_ID=""
UZUM_SECRET_KEY=""
UZUM_TEST_MODE=true

# SMS Service (Eskiz.uz)
SMS_EMAIL=""
SMS_PASSWORD=""
SMS_TOKEN=""

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ─── CI/CD (production serverda) ────────────────────────────────────────────
# GitHub Container Registry image nomlari
BACKEND_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/oshxona-pos/backend
FRONTEND_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/oshxona-pos/frontend

# Health check URL (deploy script uchun)
HEALTH_CHECK_URL=http://localhost:3000

# Deploy path (server da)
DEPLOY_PATH=/opt/oshxona-pos
