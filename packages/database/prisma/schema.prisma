  COMPLETED
  ABSENT
  LATE
}

model Shift {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id])
  date        DateTime
  startTime   DateTime    @map("start_time")
  endTime     DateTime    @map("end_time")
  actualStart DateTime?   @map("actual_start")
  actualEnd   DateTime?   @map("actual_end")
  status      ShiftStatus @default(SCHEDULED)
  breakMinutes Int        @default(0) @map("break_minutes")
  overtime    Int          @default(0) // minutes
  notes       String?
  tenantId    String      @map("tenant_id")
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([userId, date])
  @@index([tenantId, date])
  @@map("shifts")
}

model Attendance {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  clockIn   DateTime @map("clock_in")
  clockOut  DateTime? @map("clock_out")
  hours     Decimal? @db.Decimal(5, 2)
  isLate    Boolean  @default(false) @map("is_late")
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, clockIn])
  @@index([tenantId, clockIn])
  @@map("attendance")
}

model Payroll {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")
  baseSalary   Decimal  @map("base_salary") @db.Decimal(12, 2)
  overtimePay  Decimal  @default(0) @map("overtime_pay") @db.Decimal(12, 2)
  bonuses      Decimal  @default(0) @db.Decimal(12, 2)
  deductions   Decimal  @default(0) @db.Decimal(12, 2)
  totalPay     Decimal  @map("total_pay") @db.Decimal(12, 2)
  isPaid       Boolean  @default(false) @map("is_paid")
  paidAt       DateTime? @map("paid_at")
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([userId, periodStart, periodEnd])
  @@map("payroll")
}

// ==========================================
// TELEGRAM BOT
// ==========================================

model TelegramUser {
  id         String   @id @default(uuid())
  chatId     String   @unique @map("chat_id")
  username   String?
  firstName  String?  @map("first_name")
  phone      String?
  customerId String?  @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])
  language   String   @default("uz")
  isActive   Boolean  @default(true) @map("is_active")
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([tenantId, chatId])
  @@map("telegram_users")
}

// ==========================================
// SMS XABARLAR
// ==========================================

enum SmsType {
  OTP
  ORDER_STATUS
  RESERVATION
  MARKETING
  LOYALTY
}

enum SmsStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

model SmsLog {
  id        String    @id @default(uuid())
  phone     String
  type      SmsType
  message   String
  status    SmsStatus @default(PENDING)
  provider  String    @default("eskiz") // eskiz, playmobile
  externalId String?  @map("external_id")
  cost      Decimal?  @db.Decimal(8, 2)
  sentAt    DateTime? @map("sent_at")
  tenantId  String    @map("tenant_id")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([tenantId, type])
  @@index([phone, tenantId])
  @@map("sms_logs")
}

// ==========================================
// UNIVERSAL WEBHOOK PROVIDER (Tashqi yetkazib berish xizmatlari)
// ==========================================

enum WebhookProviderName {
  YANDEX_EATS
  DELIVERY_CLUB
  EXPRESS24
  OLX_FOOD
  CUSTOM
}

model WebhookProvider {
  id           String              @id @default(uuid())
  tenantId     String              @map("tenant_id")
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  providerName WebhookProviderName @map("provider_name")
  isActive     Boolean             @default(true) @map("is_active")
  secret       String?
  fieldMapping Json?               @map("field_mapping")
  statusMapping Json?              @map("status_mapping")
  notes        String?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  retryQueue   WebhookRetryQueue[]

  @@unique([tenantId, providerName])
  @@index([tenantId, isActive])
  @@map("webhook_providers")
}

model WebhookRetryQueue {
  id          String          @id @default(uuid())
  providerId  String          @map("provider_id")
  provider    WebhookProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  payload     Json
  attempts    Int             @default(0)
  maxAttempts Int             @default(5) @map("max_attempts")
  lastError   String?         @map("last_error")
  nextRetryAt DateTime        @map("next_retry_at")
  resolved    Boolean         @default(false)
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([resolved, nextRetryAt])
  @@index([providerId])
  @@map("webhook_retry_queue")
}
