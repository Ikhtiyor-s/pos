// Oshxona POS Tizimi - Ma'lumotlar Bazasi Sxemasi (Multi-Tenant SaaS)
// Generator va datasource konfiguratsiyasi

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// TENANT (RESTORAN)
// ==========================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?  @unique
  logo      String?
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Fillial (branch) tizimi — iyerarxik tenant
  parentId  String?  @map("parent_id")
  parent    Tenant?  @relation("TenantBranches", fields: [parentId], references: [id])
  children  Tenant[] @relation("TenantBranches")

  users          User[]
  categories     Category[]
  products       Product[]
  tables         Table[]
  orders         Order[]
  customers      Customer[]
  suppliers      Supplier[]
  inventoryItems InventoryItem[]
  settings       Settings?
  webhooks       Webhook[]
  subscription   Subscription?

  // Yangi modullar
  expenses              Expense[]
  expenseCategories     ExpenseCategory[]
  incomes               Income[]
  cashRegisters         CashRegister[]
  financialReports      FinancialReport[]
  onlineOrders          OnlineOrder[]
  purchaseOrders        PurchaseOrder[]
  stockAlerts           StockAlert[]
  wasteLogs             WasteLog[]
  notifications         Notification[]
  notificationSettings  NotificationSetting[]
  analyticsSnapshots    AnalyticsSnapshot[]
  forecasts             Forecast[]
  generatedReports      GeneratedReport[]

  // Yangi modullar v3.1
  loyaltyProgram        LoyaltyProgram?
  loyaltyAccounts       LoyaltyAccount[]
  coupons               Coupon[]
  reservations          Reservation[]
  drivers               Driver[]
  deliveries            Delivery[]
  shifts                Shift[]
  attendances           Attendance[]
  payrolls              Payroll[]
  telegramUsers         TelegramUser[]
  smsLogs               SmsLog[]
  webhookProviders      WebhookProvider[]

  @@index([parentId])
  @@index([slug])
  @@index([isActive])
  @@map("tenants")
}

// ==========================================
// FOYDALANUVCHILAR VA AUTENTIFIKATSIYA
// ==========================================

enum Role {
  SUPER_ADMIN
  MANAGER
  CASHIER
  CHEF
  WAITER
  WAREHOUSE
  ACCOUNTANT
}

model User {
  id        String   @id @default(uuid())
  email     String
  phone     String?
  password  String
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  role      Role     @default(CASHIER)
  avatar    String?
  pinCode        String?  @map("pin_code")
  pinQuickLookup String?  @map("pin_quick_lookup")
  isActive       Boolean  @default(true) @map("is_active")
  tenantId       String?  @map("tenant_id")
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders                Order[]
  inventoryTransactions InventoryTransaction[]
  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  expenses              Expense[]
  cashRegisters         CashRegister[]
  purchaseOrders        PurchaseOrder[]
  notifications         Notification[]
  shifts                Shift[]
  attendances           Attendance[]
  payrolls              Payroll[]
  generatedReports      GeneratedReport[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([role, tenantId])
  @@index([isActive, tenantId])
  @@index([pinQuickLookup, tenantId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

// ==========================================
// MAHSULOTLAR VA KATEGORIYALAR
// ==========================================

model Category {
  id               String   @id @default(uuid())
  name             String
  nameRu           String?  @map("name_ru")
  nameEn           String?  @map("name_en")
  slug             String
  image            String?
  sortOrder        Int      @default(0) @map("sort_order")
  isActive         Boolean  @default(true) @map("is_active")
  nonborCategoryId Int?     @map("nonbor_category_id")
  tenantId         String   @map("tenant_id")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  products Product[]

  @@unique([slug, tenantId])
  @@unique([nonborCategoryId, tenantId])
  @@index([tenantId, isActive])
  @@index([sortOrder])
  @@map("categories")
}

model Product {
  id              String   @id @default(uuid())
  name            String
  nameRu          String?  @map("name_ru")
  nameEn          String?  @map("name_en")
  description     String?
  descriptionRu   String?  @map("description_ru")
  descriptionEn   String?  @map("description_en")
  sku             String?
  barcode         String?
  price           Decimal  @db.Decimal(12, 2)
  costPrice       Decimal? @map("cost_price") @db.Decimal(12, 2)
  image           String?
  images          String[] @default([])
  categoryId      String   @map("category_id")
  category        Category @relation(fields: [categoryId], references: [id])
  isActive        Boolean  @default(true) @map("is_active")
  isFeatured      Boolean  @default(false) @map("is_featured")
  // Og'irligi va o'lchov birligi
  weight          Decimal? @db.Decimal(12, 3)
  weightUnit      String?  @default("g") @map("weight_unit")
  // Taymer va kaloriya
  cookingTime     Int?     @map("cooking_time")
  preparationTime Int?     @map("preparation_time")
  calories        Int?
  // Zaxira
  stockQuantity   Int?     @map("stock_quantity")
  lowStockAlert   Int?     @map("low_stock_alert")
  trackStock      Boolean  @default(false) @map("track_stock")
  // Teglar va qidiruv
  tags            String[] @default([])
  // Tartib va integratsiya
  sortOrder       Int      @default(0) @map("sort_order")
  nonborProductId Int?     @map("nonbor_product_id")
  // QR menyu uchun
  isAvailableOnline Boolean @default(true) @map("is_available_online")
  // MXIK — O'zbekiston Mahsulot va Xizmatlar Identifikatsiya Kodi (soliq hisoboti)
  mxikCode        String?  @map("mxik_code")
  mxikName        String?  @map("mxik_name")
  mxikVatRate     Int?     @map("mxik_vat_rate")    // 0, 12 yoki 20 foiz
  mxikExcise      Decimal? @map("mxik_excise") @db.Decimal(12, 2)
  mxikVerified    Boolean  @default(false) @map("mxik_verified")
  // Tenant
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  variants    ProductVariant[]
  modifiers   ProductModifier[]
  ingredients ProductIngredient[]
  orderItems  OrderItem[]

  @@unique([barcode, tenantId])
  @@unique([nonborProductId, tenantId])
  @@index([mxikCode, tenantId])
  @@index([tenantId, isActive])
  @@index([categoryId, tenantId])
  @@index([tenantId, isActive, isAvailableOnline])
  @@index([tenantId, isFeatured])
  @@index([sortOrder])
  @@map("products")
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  nameRu    String? @map("name_ru")
  nameEn    String? @map("name_en")
  price     Decimal @db.Decimal(12, 2)
  isActive  Boolean @default(true) @map("is_active")

  @@map("product_variants")
}

model ProductModifier {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  nameRu    String? @map("name_ru")
  nameEn    String? @map("name_en")
  price     Decimal @db.Decimal(12, 2)
  isActive  Boolean @default(true) @map("is_active")

  @@map("product_modifiers")
}

model ProductIngredient {
  id              String        @id @default(uuid())
  productId       String        @map("product_id")
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItemId String        @map("inventory_item_id")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Decimal       @db.Decimal(12, 3)

  @@map("product_ingredients")
}

// ==========================================
// STOLLAR VA BUYURTMALAR
// ==========================================

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  CLEANING
}

model Table {
  id        String      @id @default(uuid())
  number    Int
  name      String?
  capacity  Int         @default(4)
  qrCode    String      @map("qr_code")
  status    TableStatus @default(FREE)
  positionX Int?        @map("position_x")
  positionY Int?        @map("position_y")
  isActive  Boolean     @default(true) @map("is_active")
  tenantId  String      @map("tenant_id")
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  orders       Order[]
  reservations Reservation[]

  @@unique([number, tenantId])
  @@unique([qrCode, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, isActive])
  @@map("tables")
}

enum OrderSource {
  POS_ORDER
  WAITER_ORDER
  QR_ORDER
  NONBOR_ORDER
  TELEGRAM_ORDER
  WEBSITE_ORDER
  API_ORDER
  WEBHOOK_ORDER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  COMPLETED
  CANCELLED
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @map("order_number")
  source          OrderSource @default(POS_ORDER)
  type            OrderType   @default(DINE_IN)
  status          OrderStatus @default(NEW)
  tableId         String?     @map("table_id")
  table           Table?      @relation(fields: [tableId], references: [id])
  customerId      String?     @map("customer_id")
  customer        Customer?   @relation(fields: [customerId], references: [id])
  userId          String      @map("user_id")
  user            User        @relation(fields: [userId], references: [id])
  subtotal        Decimal     @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  discountPercent Decimal?    @default(0) @map("discount_percent") @db.Decimal(5, 2)
  tax             Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  notes           String?
  address         String?
  nonborOrderId   Int?        @map("nonbor_order_id")
  isNonborOrder   Boolean     @default(false) @map("is_nonbor_order")
  tenantId        String      @map("tenant_id")
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  items        OrderItem[]
  payments     Payment[]
  onlineOrder  OnlineOrder?
  delivery     Delivery?

  @@unique([orderNumber, tenantId])
  @@unique([nonborOrderId, tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, source])
  @@index([tenantId, status, createdAt])
  @@index([tableId, status])
  @@index([userId, tenantId])
  @@index([customerId])
  @@map("orders")
}

enum ItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

model OrderItem {
  id        String     @id @default(uuid())
  orderId   String     @map("order_id")
  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String     @map("product_id")
  product   Product    @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal    @db.Decimal(12, 2)
  total     Decimal    @db.Decimal(12, 2)
  notes     String?
  status    ItemStatus @default(PENDING)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([productId])
  @@index([status])
  @@map("order_items")
}

// ==========================================
// TO'LOVLAR
// ==========================================

enum PaymentMethod {
  CASH
  CARD
  PAYME
  CLICK
  UZUM
  HUMO
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @map("order_id")
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method        PaymentMethod
  amount        Decimal       @db.Decimal(12, 2)
  status        PaymentStatus @default(PENDING)
  reference     String?
  transactionId String?       @map("transaction_id")
  providerData  Json?         @map("provider_data")
  receiptData   Json?         @map("receipt_data")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([status])
  @@index([method])
  @@map("payments")
}

// ==========================================
// OMBOR BOSHQARUVI
// ==========================================

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items          InventoryItem[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model InventoryItem {
  id          String    @id @default(uuid())
  name        String
  nameRu      String?   @map("name_ru")
  nameEn      String?   @map("name_en")
  sku         String
  unit        String
  quantity    Decimal   @default(0) @db.Decimal(12, 3)
  minQuantity Decimal   @default(0) @map("min_quantity") @db.Decimal(12, 3)
  costPrice   Decimal   @default(0) @map("cost_price") @db.Decimal(12, 2)
  supplierId  String?   @map("supplier_id")
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  expiryDate  DateTime? @map("expiry_date")
  image       String?
  isActive    Boolean   @default(true) @map("is_active")
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  transactions      InventoryTransaction[]
  ingredients       ProductIngredient[]
  stockAlerts       StockAlert[]
  purchaseOrderItems PurchaseOrderItem[]
  wasteLogs         WasteLog[]

  @@unique([sku, tenantId])
  @@index([tenantId, isActive])
  @@index([supplierId])
  @@index([tenantId, quantity])
  @@map("inventory_items")
}

enum TransactionType {
  IN
  OUT
  ADJUST
  WASTE
}

model InventoryTransaction {
  id        String          @id @default(uuid())
  itemId    String          @map("item_id")
  item      InventoryItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      TransactionType
  quantity  Decimal         @db.Decimal(12, 3)
  notes     String?
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id])
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([itemId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_transactions")
}

// ==========================================
// MIJOZLAR
// ==========================================

model Customer {
  id          String    @id @default(uuid())
  phone       String
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  email       String?
  birthDate   DateTime? @map("birth_date")
  bonusPoints Int       @default(0) @map("bonus_points")
  notes       String?
  isActive    Boolean   @default(true) @map("is_active")
  tenantId    String    @map("tenant_id")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  orders          Order[]
  loyaltyAccount  LoyaltyAccount?
  reservations    Reservation[]
  telegramUsers   TelegramUser[]

  @@unique([phone, tenantId])
  @@index([tenantId])
  @@map("customers")
}

// ==========================================
// TIZIM SOZLAMALARI
// ==========================================

model Settings {
  id              String  @id @default(uuid())
  tenantId        String  @unique @map("tenant_id")
  tenant          Tenant  @relation(fields: [tenantId], references: [id])
  name            String
  nameRu          String? @map("name_ru")
  nameEn          String? @map("name_en")
  address         String?
  phone           String?
  email           String?
  taxRate         Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  currency        String  @default("UZS")
  logo            String?
  timezone        String  @default("Asia/Tashkent")
  orderPrefix     String  @default("ORD") @map("order_prefix")
  bonusPercent    Decimal @default(0) @map("bonus_percent") @db.Decimal(5, 2)
  nonborEnabled   Boolean @default(false) @map("nonbor_enabled")
  nonborSellerId  Int?    @map("nonbor_seller_id")
  nonborApiUrl    String? @default("https://test.nonbor.uz/api/v2") @map("nonbor_api_url")
  nonborApiSecret String? @default("nonbor-secret-key") @map("nonbor_api_secret")

  // To'lov integratsiyalar
  paymeEnabled      Boolean  @default(false) @map("payme_enabled")
  paymeMerchantId   String?  @map("payme_merchant_id")
  paymeSecretKey    String?  @map("payme_secret_key")
  paymeTestMode     Boolean  @default(true) @map("payme_test_mode")

  clickEnabled      Boolean  @default(false) @map("click_enabled")
  clickMerchantId   String?  @map("click_merchant_id")
  clickServiceId    String?  @map("click_service_id")
  clickSecretKey    String?  @map("click_secret_key")
  clickTestMode     Boolean  @default(true) @map("click_test_mode")

  uzumEnabled       Boolean  @default(false) @map("uzum_enabled")
  uzumMerchantId    String?  @map("uzum_merchant_id")
  uzumSecretKey     String?  @map("uzum_secret_key")
  uzumTestMode      Boolean  @default(true) @map("uzum_test_mode")

  // Telegram
  telegramEnabled   Boolean  @default(false) @map("telegram_enabled")
  telegramBotToken  String?  @map("telegram_bot_token")
  telegramChatId    String?  @map("telegram_chat_id")
  telegramEvents    String[] @default(["order:new"]) @map("telegram_events")

  // Delivery
  deliveryEnabled   Boolean  @default(false) @map("delivery_enabled")
  deliveryApiUrl    String?  @map("delivery_api_url")
  deliveryApiKey    String?  @map("delivery_api_key")

  // CRM
  crmEnabled        Boolean  @default(false) @map("crm_enabled")
  crmApiUrl         String?  @map("crm_api_url")
  crmApiKey         String?  @map("crm_api_key")
  crmEvents         String[] @default(["order:new", "order:completed"]) @map("crm_events")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ==========================================
// WEBHOOKLAR (Tashqi servis integratsiya)
// ==========================================

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  secret    String?
  events    String[]
  headers   Json?
  isActive  Boolean  @default(true) @map("is_active")
  service   String?
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  logs WebhookLog[]

  @@map("webhooks")
}

model WebhookLog {
  id         String   @id @default(uuid())
  webhookId  String   @map("webhook_id")
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event      String
  payload    Json
  response   Json?
  statusCode Int?     @map("status_code")
  success    Boolean  @default(false)
  direction  String   @default("outgoing")
  error      String?
  duration   Int?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("webhook_logs")
}

// ==========================================
// AUDIT LOG (Tizim loglari)
// ==========================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  tenantId   String?  @map("tenant_id")
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ==========================================
// INTEGRATION LOGS (Integratsiya loglari)
// ==========================================

model IntegrationLog {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id")
  adapter   String
  event     String
  payload   Json
  status    String
  error     String?
  duration  Int?
  attempt   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("integration_logs")
}

// ==========================================
// BILLING VA TARIF REJALAR
// ==========================================

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

model Plan {
  id                String   @id @default(uuid())
  name              String   @unique
  nameRu            String?  @map("name_ru")
  nameEn            String?  @map("name_en")
  description       String?
  basePrice         Decimal  @map("base_price") @db.Decimal(12, 2)
  pricePerWarehouse Decimal  @default(0) @map("price_per_warehouse") @db.Decimal(12, 2)
  pricePerKitchen   Decimal  @default(0) @map("price_per_kitchen") @db.Decimal(12, 2)
  pricePerWaiter    Decimal  @default(0) @map("price_per_waiter") @db.Decimal(12, 2)
  maxUsers          Int      @default(5) @map("max_users")
  maxOrders         Int      @default(0) @map("max_orders")
  maxWarehouses     Int      @default(1) @map("max_warehouses")
  maxKitchens       Int      @default(1) @map("max_kitchens")
  maxWaiters        Int      @default(2) @map("max_waiters")
  hasIntegrations   Boolean  @default(false) @map("has_integrations")
  hasReports        Boolean  @default(false) @map("has_reports")
  isActive          Boolean  @default(true) @map("is_active")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
