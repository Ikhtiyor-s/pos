# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/oshxona_pos"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173,http://localhost:5174,http://localhost:5175"

# ─── Redis (BullMQ queues) ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Tenant ───────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID="your-tenant-uuid"

# ─── Payments ─────────────────────────────────────────────────────────────────
PAYME_MERCHANT_ID=""
PAYME_SECRET_KEY=""
CLICK_MERCHANT_ID=""
CLICK_SECRET_KEY=""
UZUM_MERCHANT_ID=""
UZUM_SECRET_KEY=""

# ─── Telegram (notifications) ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ─── Nonbor integration ───────────────────────────────────────────────────────
NONBOR_API_URL="https://test.nonbor.uz/api/v2"
NONBOR_API_KEY=""

# ─── SMS ──────────────────────────────────────────────────────────────────────
SMS_API_URL=""
SMS_API_KEY=""
