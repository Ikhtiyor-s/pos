{
  "uid": "oshxona-pos-main",
  "title": "Oshxona POS — Monitoring",
  "description": "API, Database, Redis, Orders real-time dashboard",
  "tags": ["oshxona", "pos", "production"],
  "timezone": "Asia/Tashkent",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "label": "Endpoint",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(http_requests_total, endpoint)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2
      },
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource"
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "title": "So'rovlar (req/s)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "targets": [{
        "expr": "sum(rate(http_requests_total[1m]))",
        "legendFormat": "req/s"
      }]
    },

    {
      "id": 2,
      "title": "5xx Error Rate",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
        "legendFormat": "error rate"
      }]
    },

    {
      "id": 3,
      "title": "P95 Response Time",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
        "legendFormat": "p95"
      }]
    },

    {
      "id": 4,
      "title": "Faol Socket ulanishlar",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(socket_io_active_connections)",
        "legendFormat": "connections"
      }]
    },

    {
      "id": 5,
      "title": "Redis Hit Ratio",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "avg(redis_hit_ratio)",
        "legendFormat": "hit ratio"
      }]
    },

    {
      "id": 6,
      "title": "Faol Tenantlar",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } }
      },
      "targets": [{
        "expr": "tenant_count_active",
        "legendFormat": "tenants"
      }]
    },

    {
      "id": 10,
      "title": "HTTP So'rovlar (endpoint bo'yicha)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (endpoint, method) (rate(http_requests_total{endpoint=~\"$endpoint\"}[1m]))",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },

    {
      "id": 11,
      "title": "Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "5xx"
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "4xx"
        }
      ]
    },

    {
      "id": 20,
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "id": 21,
      "title": "Database So'rov Davomiyligi",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, operation) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{operation}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{operation}}"
        }
      ]
    },

    {
      "id": 30,
      "title": "Buyurtmalar (real-time)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum(rate(orders_created_total[5m])) * 60",
          "legendFormat": "Yaratilgan (min)"
        },
        {
          "expr": "sum(rate(orders_completed_total[5m])) * 60",
          "legendFormat": "Yakunlangan (min)"
        },
        {
          "expr": "sum(orders_active_count)",
          "legendFormat": "Faol"
        }
      ]
    },

    {
      "id": 31,
      "title": "Nonbor Sync Xatoliklar",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum by (error_type) (increase(nonbor_sync_errors_total[5m]))",
          "legendFormat": "{{error_type}}"
        }
      ]
    },

    {
      "id": 40,
      "title": "Node.js Heap Memory",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      },
      "targets": [
        {
          "expr": "nodejs_heap_used_bytes",
          "legendFormat": "Heap used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes",
          "legendFormat": "Heap total"
        },
        {
          "expr": "nodejs_external_memory_bytes",
          "legendFormat": "External"
        }
      ]
    },

    {
      "id": 41,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 28, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "event loop lag"
        }
      ]
    },

    {
      "id": 42,
      "title": "Disk Space",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true },
      "targets": [{
        "expr": "1 - (disk_space_bytes{type=\"available\"} / disk_space_bytes{type=\"total\"})",
        "legendFormat": "Disk used %"
      }]
    },

    {
      "id": 50,
      "title": "Active Connections Timeline",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 35, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum by (tenant_id) (socket_io_active_connections)",
          "legendFormat": "tenant: {{tenant_id}}"
        }
      ]
    },

    {
      "id": 51,
      "title": "Redis Operations",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 35, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "sum(rate(redis_cache_hits_total[1m]))",
          "legendFormat": "Hits/s"
        },
        {
          "expr": "sum(rate(redis_cache_misses_total[1m]))",
          "legendFormat": "Misses/s"
        }
      ]
    }
  ]
}
